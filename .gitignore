# IntelliJ IDEA / JetBrains
# Keep shared project files when needed:
# - .idea/vcs.xml
# - .idea/modules.xml
# - .idea/*.iml
#
# Ignore only user-local volatile state.
.idea/workspace.xml
.idea/workspace.xml.*
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/shelf/
.idea/httpRequests/
*.iws

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Obsidian volatile UI state
# These files store local workspace/graph layout and are not Harness facts.
harness/.obsidian/workspace.json
harness/.obsidian/workspace-mobile.json
harness/.obsidian/workspaces.json
harness/.obsidian/graph.json

# Obsidian community plugin runtime code
# Plugin runtime code is not a Harness fact source and should be reinstalled locally by Obsidian.
# Lightweight configuration such as manifest.json, data.json, community-plugins.json, core-plugins.json,
# app.json and appearance.json may be tracked when intentionally reviewed.
harness/.obsidian/plugins/**/main.js
harness/.obsidian/plugins/**/styles.css
harness/.obsidian/plugins/**/obsidian_askpass.sh

# Local generated / temporary files
*.tmp
*.bak
*.log

# Generated governance artifacts can be committed selectively.
harness/docs/reports/**/*.json
harness/docs/reports/**/*.html
